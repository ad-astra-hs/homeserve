# Example Caddyfile for Homeserve
# 
# This configuration:
# 1. Handles HTTPS automatically (Let's Encrypt)
# 2. Serves static assets efficiently
# 3. Enables compression
# 4. Adds security headers
# 
# Usage:
# 1. Copy this file to Caddyfile
# 2. Replace 'homeserve.example.com' with your domain
# 3. Update the root path for static assets
# 4. Run: caddy run --config Caddyfile

homeserve.example.com {
    # Enable compression for faster loading
    encode gzip zstd

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Serve static files directly without hitting the Gleam app
    # This significantly improves performance for images, CSS, JS, etc.
    handle_path /assets/* {
        root * /path/to/homeserve/priv/static
        file_server
        # Cache static assets for 1 week
        header Cache-Control "public, max-age=604800"
    }

    # Proxy all requests to Homeserve
    reverse_proxy localhost:8000 {
        # Forward the real client IP
        header_up X-Forwarded-For {remote}
        header_up X-Real-IP {remote}
        
        # Forward the original host
        header_up Host {host}
        
        # Forward the original protocol
        header_up X-Forwarded-Proto {scheme}
    }
}

# Alternative: Local development with HTTP (no HTTPS)
# Replace the above block with this for local testing:
#
# :8080 {
#     reverse_proxy localhost:8000 {
#         header_up X-Forwarded-For {remote}
#         header_up X-Real-IP {remote}
#     }
# }
