# Example Caddyfile for Homeserve
# 
# This configuration:
# 1. Handles HTTPS automatically (Let's Encrypt)
# 2. Serves static assets efficiently
# 3. Enables compression
# 4. Adds security headers
# 5. Rate limits admin endpoints

homeserve.example.com {
    # Enable compression
    encode gzip zstd

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Static file serving (optional but recommended)
    # This serves assets directly without hitting the Gleam app
    handle_path /assets/* {
        root * /path/to/homeserve/priv/static
        file_server
        # Cache static assets for 1 week
        header Cache-Control "public, max-age=604800"
    }

    # Rate limit admin endpoints: 10 requests per minute per IP
    handle_path /admin* {
        rate_limit {
            zone admin {
                key {remote_host}
                events 10
                window 1m
            }
        }
        reverse_proxy localhost:8000 {
            header_up X-Forwarded-For {remote}
            header_up X-Real-IP {remote}
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Proxy all other requests to Homeserve
    reverse_proxy localhost:8000 {
        # Forward the real client IP
        header_up X-Forwarded-For {remote}
        header_up X-Real-IP {remote}
        
        # Forward the original host
        header_up Host {host}
        
        # Forward the original protocol
        header_up X-Forwarded-Proto {scheme}
    }
}

# Alternative: Local development with HTTP
:8080 {
    # Rate limit admin endpoints for development too
    handle_path /admin* {
        rate_limit {
            zone admin {
                key {remote_host}
                events 10
                window 1m
            }
        }
        reverse_proxy localhost:8000 {
            header_up X-Forwarded-For {remote}
            header_up X-Real-IP {remote}
        }
    }

    reverse_proxy localhost:8000 {
        header_up X-Forwarded-For {remote}
        header_up X-Real-IP {remote}
    }
}
